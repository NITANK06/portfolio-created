import { create } from 'zustand';

const usePortfolioStore = create((set) => ({
  stocks: [],

  addStock: (stock) =>
    set((state) => ({
      stocks: [...state.stocks, stock],
    })),

  removeStock: (symbol) =>
    set((state) => ({
      stocks: state.stocks.filter((s) => s.symbol !== symbol),
    })),

export default usePortfolioStore;
}));
